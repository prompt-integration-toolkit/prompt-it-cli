{
  "name": "prompt-it-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI tool for storing, organizing, versioning, and reusing prompts.",
  "bin": {
    "prompt-it": "./bin/prompt-it.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "node ./bin/prompt-it.js",
    "start": "node ./bin/prompt-it.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@supabase/supabase-js": "^2.106.1",
    "chalk": "^5.0.0",
    "clipboardy": "^4.0.0",
    "commander": "^14.0.0",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^7.0.2",
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.63.0"
  }
}
